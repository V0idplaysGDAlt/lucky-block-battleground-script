		task.wait(1) -- wait for backpack to refill
		if killEnabled then stopSpawnLoop() end
		if crescEnabled then stopSpawnLoop() end
	end)

	-- ── Crescendo loop ────────────────────────────────
	local crescStatusLbl  -- forward ref

	-- Current target root for the float lock
	local crescTargetRoot = nil
	local crescFloatConn  = nil

	local function startFloatLock()
		if crescFloatConn then crescFloatConn:Disconnect() end
		-- Use Heartbeat so it fires every ~0.01s and keeps us frozen above target
		crescFloatConn = RunService.Heartbeat:Connect(function()
			if not crescEnabled or not crescTargetRoot then return end
			pcall(function()
				local abovePos = crescTargetRoot.Position + Vector3.new(0, 50, 0)
				rootPart.CFrame = CFrame.new(abovePos)
				-- Zero velocity so we don't drift
				rootPart.AssemblyLinearVelocity  = Vector3.zero
				rootPart.AssemblyAngularVelocity = Vector3.zero
			end)
		end)
		table.insert(_G.V0idConnections, crescFloatConn)
	end

	local function stopFloatLock()
		if crescFloatConn then crescFloatConn:Disconnect(); crescFloatConn = nil end
		crescTargetRoot = nil
	end

	local function pressE()
		-- Method 1: executor-level keypress (works in most exploits)
		pcall(function() keypress(0x45) end)
		task.wait(0.05)
		pcall(function() keyrelease(0x45) end)

		-- Method 2: VirtualInputManager
		pcall(function()
			local vim = game:GetService("VirtualInputManager")
			vim:SendKeyEvent(true,  Enum.KeyCode.E, false, game)
			task.wait(0.05)
			vim:SendKeyEvent(false, Enum.KeyCode.E, false, game)
		end)

		-- Method 3: fire every RemoteEvent on the tool directly
		pcall(function()
			local tool = findCrescendo()
			if tool and tool.Parent == character then
				for _, v in ipairs(tool:GetDescendants()) do
					if v:IsA("RemoteEvent") then
						pcall(function() v:FireServer() end)
					end
				end
				-- Also call Activate directly
				pcall(function() tool:Activate() end)
			end
		end)
	end

	local function runCrescLoop()
		while crescEnabled do
			if not character or not character:FindFirstChildOfClass("Humanoid")
			or character:FindFirstChildOfClass("Humanoid").Health <= 0 then
				task.wait(0.5); continue
			end

			local tool = findCrescendo()
			if not tool then
				stopFloatLock()
				if crescStatusLbl then
					crescStatusLbl.Text = "🔍 Crescendo: Not detected"
					crescStatusLbl.TextColor3 = Color3.fromRGB(255,100,100)
				end
				task.wait(0.5); continue
			end

			equipTool(tool)

			local targets = getTargets()
			if #targets == 0 then
				stopFloatLock()
				if crescStatusLbl then
					crescStatusLbl.Text = "⚠️ No targets outside base"
					crescStatusLbl.TextColor3 = Color3.fromRGB(255,200,80)
				end
				task.wait(0.5); continue
			end

			for _, plr in ipairs(targets) do
				if not crescEnabled then break end

				while crescEnabled do
					local myHum = character and character:FindFirstChildOfClass("Humanoid")
					if not myHum or myHum.Health <= 0 then stopFloatLock(); task.wait(0.5); break end

					local char2  = plr.Character
					local hum2   = char2 and char2:FindFirstChildOfClass("Humanoid")
					local root2  = char2 and char2:FindFirstChild("HumanoidRootPart")
					if not char2 or not hum2 or not root2 or hum2.Health <= 0 then
						stopFloatLock(); break
					end
					if isInBase(root2.Position) then stopFloatLock(); break end

					tool = findCrescendo()
					if not tool then stopFloatLock(); break end

					if crescStatusLbl then
						crescStatusLbl.Text = "🎵 Targeting: " .. plr.Name
						crescStatusLbl.TextColor3 = Color3.fromRGB(100,200,255)
					end

					-- Lock float above this target via Heartbeat
					crescTargetRoot = root2
					startFloatLock()

					-- Spam E every 5 seconds
					pressE()
					task.wait(5)
				end
			end

			task.wait(0.1)
		end
		stopFloatLock()
	end

	local function stopCresc()
		crescEnabled = false
		crescThread  = nil
		stopFloatLock()
	end

	local function startCresc()
		crescEnabled = true
		crescThread  = task.spawn(runCrescLoop)
	end

