	dropOverlay.BackgroundColor3=Color3.fromRGB(12,0,24); dropOverlay.BorderSizePixel=0
	dropOverlay.ZIndex=50; dropOverlay.Visible=false; dropOverlay.Size=UDim2.new(0,0,0,0)
	local dlc=Instance.new("UICorner"); dlc.CornerRadius=UDim.new(0,8); dlc.Parent=dropOverlay
	local dlStroke=Instance.new("UIStroke"); dlStroke.Color=Color3.fromRGB(100,0,180)
	dlStroke.Thickness=1; dlStroke.Parent=dropOverlay

	local function closeDropdown()
		dropdownOpen=false; dropOverlay.Visible=false
		dropdownBtn.Text="  ▼  "..(selectedConfig or "Select a config...")
	end

	rebuildDropdown = function()
		for _,ch in ipairs(dropOverlay:GetChildren()) do
			if ch:IsA("TextButton") or ch:IsA("ScrollingFrame") then ch:Destroy() end
		end
		local names={}
		for k in pairs(_G.V0idConfigs) do table.insert(names,k) end
		table.sort(names)
		if #names==0 then dropdownBtn.Text="  ▼  No configs saved"; closeDropdown(); return end
		local maxVisible=6
		local totalH=math.min(#names,maxVisible)*listItemH
		local btnAbs=dropdownBtn.AbsolutePosition; local btnSz=dropdownBtn.AbsoluteSize
		dropOverlay.Position=UDim2.new(0,btnAbs.X,0,btnAbs.Y+btnSz.Y+4)
		dropOverlay.Size=UDim2.new(0,btnSz.X,0,totalH)
		local scroll=Instance.new("ScrollingFrame"); scroll.Parent=dropOverlay
		scroll.Size=UDim2.new(1,0,1,0); scroll.BackgroundTransparency=1
		scroll.BorderSizePixel=0; scroll.ScrollBarThickness=3
		scroll.ScrollBarImageColor3=Color3.fromRGB(130,0,200)
		scroll.CanvasSize=UDim2.new(0,0,0,#names*listItemH); scroll.ZIndex=51
		for i,name in ipairs(names) do
			local item=Instance.new("TextButton"); item.Parent=scroll
			item.Size=UDim2.new(1,0,0,listItemH); item.Position=UDim2.new(0,0,0,(i-1)*listItemH)
			item.BackgroundColor3=(name==selectedConfig) and Color3.fromRGB(70,0,120) or Color3.fromRGB(20,0,38)
			item.Text="  "..name; item.Font=Enum.Font.GothamBold; item.TextSize=13
			item.TextColor3=Color3.new(1,1,1); item.TextXAlignment=Enum.TextXAlignment.Left
			item.BorderSizePixel=0; item.ZIndex=52
			local ihov=Instance.new("UICorner"); ihov.CornerRadius=UDim.new(0,4); ihov.Parent=item
			item.MouseEnter:Connect(function() if name~=selectedConfig then item.BackgroundColor3=Color3.fromRGB(40,0,70) end end)
			item.MouseLeave:Connect(function() item.BackgroundColor3=(name==selectedConfig) and Color3.fromRGB(70,0,120) or Color3.fromRGB(20,0,38) end)
			item.MouseButton1Click:Connect(function() selectedConfig=name; closeDropdown(); rebuildDropdown() end)
		end
	end

	dropdownBtn.MouseButton1Click:Connect(function()
		if dropdownOpen then closeDropdown()
		else
			dropdownOpen=true; rebuildDropdown(); dropOverlay.Visible=true
			dropdownBtn.Text="  ▲  "..(selectedConfig or "Select a config...")
		end
	end)

	local _overlayConn=UIS.InputBegan:Connect(function(inp)
		if not dropdownOpen then return end
		if inp.UserInputType==Enum.UserInputType.MouseButton1 or inp.UserInputType==Enum.UserInputType.Touch then
			local mp=inp.Position
			local op=dropOverlay.AbsolutePosition; local os=dropOverlay.AbsoluteSize
			local inside=(mp.X>=op.X and mp.X<=op.X+os.X and mp.Y>=op.Y and mp.Y<=op.Y+os.Y)
			local bp=dropdownBtn.AbsolutePosition; local bs=dropdownBtn.AbsoluteSize
			local onBtn=(mp.X>=bp.X and mp.X<=bp.X+bs.X and mp.Y>=bp.Y and mp.Y<=bp.Y+bs.Y)
			if not inside and not onBtn then closeDropdown() end
		end
	end)
	table.insert(_G.V0idConnections, _overlayConn)

	local loadBtn=Instance.new("TextButton"); loadBtn.Parent=p
	loadBtn.Size=UDim2.new(1,-20,0,34); loadBtn.Position=UDim2.new(0,10,0,y)
	loadBtn.BackgroundColor3=Color3.fromRGB(20,60,120); loadBtn.TextColor3=Color3.new(1,1,1)
	loadBtn.Text="📂  Load Selected"; loadBtn.Font=Enum.Font.GothamBold; loadBtn.TextSize=13; loadBtn.BorderSizePixel=0
	local lbc=Instance.new("UICorner"); lbc.CornerRadius=UDim.new(0,6); lbc.Parent=loadBtn
	loadBtn.MouseButton1Click:Connect(function()
		if not selectedConfig then flashStatus(statusLbl,"❌ Select a config first.",Color3.fromRGB(255,80,80)); return end
		local raw=_G.V0idConfigs[selectedConfig]
		if not raw then flashStatus(statusLbl,"❌ Config not found.",Color3.fromRGB(255,80,80)); return end
		local ok,cfg=pcall(function() return HttpService:JSONDecode(raw) end)
		if ok and type(cfg)=="table" then applyConfig(cfg); flashStatus(statusLbl,'✅ Loaded "'..selectedConfig..'"')
		else flashStatus(statusLbl,"❌ Corrupted config.",Color3.fromRGB(255,80,80)) end
	end)
	y+=42

	local delBtn=Instance.new("TextButton"); delBtn.Parent=p
	delBtn.Size=UDim2.new(1,-20,0,34); delBtn.Position=UDim2.new(0,10,0,y)
	delBtn.BackgroundColor3=Color3.fromRGB(100,0,0); delBtn.TextColor3=Color3.new(1,1,1)
	delBtn.Text="🗑️  Delete Selected"; delBtn.Font=Enum.Font.GothamBold; delBtn.TextSize=13; delBtn.BorderSizePixel=0
	local dbc2=Instance.new("UICorner"); dbc2.CornerRadius=UDim.new(0,6); dbc2.Parent=delBtn
	delBtn.MouseButton1Click:Connect(function()
		if not selectedConfig then flashStatus(statusLbl,"❌ Select a config first.",Color3.fromRGB(255,80,80)); return end
		_G.V0idConfigs[selectedConfig]=nil; persistToFile()
		flashStatus(statusLbl,'🗑️ Deleted "'..selectedConfig..'"')
		selectedConfig=nil; rebuildDropdown()
	end)
	y+=42

	addLabel(p, "Reset", y); y+=22

	local resetBtn=Instance.new("TextButton"); resetBtn.Parent=p
	resetBtn.Size=UDim2.new(1,-20,0,34); resetBtn.Position=UDim2.new(0,10,0,y)
	resetBtn.BackgroundColor3=Color3.fromRGB(120,30,0); resetBtn.TextColor3=Color3.new(1,1,1)
	resetBtn.Text="⚠️  Reset All Features"; resetBtn.Font=Enum.Font.GothamBold; resetBtn.TextSize=13; resetBtn.BorderSizePixel=0
	local rbc=Instance.new("UICorner"); rbc.CornerRadius=UDim.new(0,6); rbc.Parent=resetBtn
	resetBtn.MouseButton1Click:Connect(function()
		targetSpeed=16; targetJump=50; speedEnabled=false
		if humanoid then humanoid.WalkSpeed=16; humanoid.JumpPower=50 end
		flyEnabled=false; stopFly()
		infJumpEnabled=false; noclipEnabled=false
		if godEnabled then
			godEnabled=false
			if humanoid then
				pcall(function() humanoid.MaxHealth=100 end)
				pcall(function() humanoid.Health=100 end)
			end
		end
		customGravity=196.2; workspace.Gravity=196.2
		if character then
			for _,part in ipairs(character:GetDescendants()) do
				if part:IsA("BasePart") then pcall(function() part.CanCollide=true end) end
			end
		end
		espBoxEnabled=false; espTracerEnabled=false; espNameEnabled=false
		espHealthEnabled=false; espDistEnabled=false; espHeadDotEnabled=false
		espSkeletonEnabled=false; espChamsEnabled=false
		espOutlineEnabled=false; espRainbow=false
		stopEsp(); aimbotEnabled=false; setFullbright(false)
		flashStatus(statusLbl,"✅ All features reset.")
	end)
	y+=42

	-- ── THEMES ──────────────────────────────────────
	addLabel(p, "Themes", y); y+=22

	local themes = {
		{ name="Void",      bg=Color3.fromRGB(10,0,20),   bar=Color3.fromRGB(20,0,40),   tab=Color3.fromRGB(15,0,30),   accent=Color3.fromRGB(130,0,200),  text=Color3.fromRGB(170,0,255)  },
		{ name="Midnight",  bg=Color3.fromRGB(5,5,20),    bar=Color3.fromRGB(10,10,40),  tab=Color3.fromRGB(8,8,30),    accent=Color3.fromRGB(50,80,200),  text=Color3.fromRGB(100,140,255) },
		{ name="Crimson",   bg=Color3.fromRGB(20,0,0),    bar=Color3.fromRGB(40,0,0),    tab=Color3.fromRGB(30,0,0),    accent=Color3.fromRGB(180,0,0),    text=Color3.fromRGB(255,60,60)  },
		{ name="Forest",    bg=Color3.fromRGB(0,15,5),    bar=Color3.fromRGB(0,28,8),    tab=Color3.fromRGB(0,20,6),    accent=Color3.fromRGB(0,140,40),   text=Color3.fromRGB(60,220,80)  },
		{ name="Ocean",     bg=Color3.fromRGB(0,10,20),   bar=Color3.fromRGB(0,20,40),   tab=Color3.fromRGB(0,15,30),   accent=Color3.fromRGB(0,100,180),  text=Color3.fromRGB(0,180,255)  },
		{ name="Gold",      bg=Color3.fromRGB(20,14,0),   bar=Color3.fromRGB(38,26,0),   tab=Color3.fromRGB(28,20,0),   accent=Color3.fromRGB(180,120,0),  text=Color3.fromRGB(255,200,0)  },
		{ name="Rose",      bg=Color3.fromRGB(20,0,10),   bar=Color3.fromRGB(40,0,20),   tab=Color3.fromRGB(30,0,15),   accent=Color3.fromRGB(200,0,80),   text=Color3.fromRGB(255,80,160) },
		{ name="Slate",     bg=Color3.fromRGB(12,14,18),  bar=Color3.fromRGB(22,26,32),  tab=Color3.fromRGB(16,18,24),  accent=Color3.fromRGB(80,100,130), text=Color3.fromRGB(160,180,210) },
	}

	local function applyTheme(t)
		frame.BackgroundColor3      = t.bg
		titleBar.BackgroundColor3   = t.bar
		titleBarFix.BackgroundColor3= t.bar
		tabBar.BackgroundColor3     = t.tab
		title.TextColor3            = t.text
		toggleButton.BackgroundColor3 = t.accent
		ACTIVE_COLOR   = t.accent
		TEXT_ACTIVE    = Color3.new(1,1,1)
		TEXT_INACTIVE  = t.text
		-- update all tab buttons
		for _, name in ipairs(tabs) do
			local btn  = tabButtons[name]
			local page = tabPages[name]
			if page.Visible then
				btn.BackgroundColor3 = t.accent
				btn.TextColor3       = Color3.new(1,1,1)
			else
				btn.BackgroundColor3 = INACTIVE_COLOR
				btn.TextColor3       = t.text
			end
		end
	end

	local themeChipW = 62; local themeChipH = 28; local themeGap = 6
	local themePerRow = 4
	for i, t in ipairs(themes) do
		local col = (i-1) % themePerRow
		local row = math.floor((i-1) / themePerRow)
		local tb = Instance.new("TextButton"); tb.Parent = p
		tb.Size = UDim2.new(0, themeChipW, 0, themeChipH)
		tb.Position = UDim2.new(0, 10 + col*(themeChipW+themeGap), 0, y + row*(themeChipH+themeGap))
		tb.BackgroundColor3 = t.accent; tb.Text = t.name
		tb.Font = Enum.Font.GothamBold; tb.TextSize = 11
		tb.TextColor3 = Color3.new(1,1,1); tb.BorderSizePixel = 0
		local tbc = Instance.new("UICorner"); tbc.CornerRadius = UDim.new(0,6); tbc.Parent = tb
		tb.MouseButton1Click:Connect(function() applyTheme(t) end)
	end
	local themeRows = math.ceil(#themes / themePerRow)
	y += themeRows*(themeChipH+themeGap) + 8

	-- ── INFO ────────────────────────────────────────
	addLabel(p, "Info", y); y+=22
	local infoLbl=Instance.new("TextLabel"); infoLbl.Parent=p
	infoLbl.Size=UDim2.new(1,-20,0,56); infoLbl.Position=UDim2.new(0,10,0,y)
	infoLbl.BackgroundColor3=Color3.fromRGB(15,0,30); infoLbl.BorderSizePixel=0
	infoLbl.Font=Enum.Font.Gotham; infoLbl.TextSize=11
	infoLbl.TextColor3=Color3.fromRGB(160,120,200); infoLbl.TextWrapped=true
	infoLbl.TextXAlignment=Enum.TextXAlignment.Left
	infoLbl.Text="  V0id Hub  |  Configs saved in _G per session\n  and to V0idHub_configs.json if writefile supported.\n  Named configs survive re-execution."
	local ilc=Instance.new("UICorner"); ilc.CornerRadius=UDim.new(0,6); ilc.Parent=infoLbl
	y+=68

	p.CanvasSize=UDim2.new(0,0,0,y+20)

	rebuildDropdown()
end

