local function addSlider(parent, labelText, minVal, maxVal, defaultVal, yOffset, onChange)
	local SH = M.sliderH
	local TH = M.trackH
	local KS = M.knobSz
	local KO = -math.floor(KS/2)

	local container = Instance.new("Frame")
	container.Parent = parent
	container.Size = UDim2.new(1, -20, 0, SH)
	container.Position = UDim2.new(0, 10, 0, yOffset)
	container.BackgroundColor3 = Color3.fromRGB(20, 0, 40)
	container.BorderSizePixel = 0
	local cCorner = Instance.new("UICorner"); cCorner.CornerRadius = UDim.new(0,6); cCorner.Parent = container

	local lbl = Instance.new("TextLabel")
	lbl.Parent = container
	lbl.Size = UDim2.new(1, -60, 0, 22)
	lbl.Position = UDim2.new(0, 10, 0, 4)
	lbl.BackgroundTransparency = 1
	lbl.Text = labelText
	lbl.Font = Enum.Font.GothamBold
	lbl.TextSize = M.textSz
	lbl.TextColor3 = Color3.fromRGB(200, 160, 255)
	lbl.TextXAlignment = Enum.TextXAlignment.Left

	local valLabel = Instance.new("TextLabel")
	valLabel.Parent = container
	valLabel.Size = UDim2.new(0, 52, 0, 22)
	valLabel.Position = UDim2.new(1, -58, 0, 4)
	valLabel.BackgroundTransparency = 1
	valLabel.Text = tostring(defaultVal)
	valLabel.Font = Enum.Font.GothamBold
	valLabel.TextSize = M.textSz
	valLabel.TextColor3 = Color3.fromRGB(170, 0, 255)
	valLabel.TextXAlignment = Enum.TextXAlignment.Right

	local trackY = SH - TH - 8
	local track = Instance.new("Frame")
	track.Parent = container
	track.Size = UDim2.new(1, -20, 0, TH)
	track.Position = UDim2.new(0, 10, 0, trackY)
	track.BackgroundColor3 = Color3.fromRGB(50, 0, 80)
	track.BorderSizePixel = 0
	local trackCorner = Instance.new("UICorner"); trackCorner.CornerRadius = UDim.new(1,0); trackCorner.Parent = track

	local fill = Instance.new("Frame")
	fill.Parent = track
	fill.Size = UDim2.new((defaultVal-minVal)/(maxVal-minVal), 0, 1, 0)
	fill.BackgroundColor3 = Color3.fromRGB(130, 0, 200)
	fill.BorderSizePixel = 0
	local fillCorner = Instance.new("UICorner"); fillCorner.CornerRadius = UDim.new(1,0); fillCorner.Parent = fill

	local knob = Instance.new("Frame")
	knob.Parent = track
	knob.Size = UDim2.new(0, KS, 0, KS)
	knob.Position = UDim2.new((defaultVal-minVal)/(maxVal-minVal), KO, 0.5, KO)
	knob.BackgroundColor3 = Color3.new(1,1,1)
	knob.BorderSizePixel = 0
	knob.ZIndex = 4
	local knobCorner = Instance.new("UICorner"); knobCorner.CornerRadius = UDim.new(1,0); knobCorner.Parent = knob

	-- Invisible hit area covers entire container so fat fingers register easily
	local hitArea = Instance.new("TextButton")
	hitArea.Parent = container
	hitArea.Size = UDim2.new(1, 0, 1, 0)
	hitArea.Position = UDim2.new(0,0,0,0)
	hitArea.BackgroundTransparency = 1
	hitArea.Text = ""
	hitArea.ZIndex = 5

	local function applyX(absX)
		local tPos = track.AbsolutePosition.X
		local tSz  = track.AbsoluteSize.X
		if tSz == 0 then return end
		local ratio = math.clamp((absX - tPos) / tSz, 0, 1)
		local val   = math.round(minVal + ratio * (maxVal - minVal))
		valLabel.Text = tostring(val)
		fill.Size = UDim2.new(ratio, 0, 1, 0)
		knob.Position = UDim2.new(ratio, KO, 0.5, KO)
		if onChange then onChange(val) end
	end

	local activeTouchId = nil

	hitArea.InputBegan:Connect(function(inp)
		if inp.UserInputType == Enum.UserInputType.Touch then
			activeTouchId = inp
			applyX(inp.Position.X)
		elseif inp.UserInputType == Enum.UserInputType.MouseButton1 then
			activeTouchId = inp
			applyX(inp.Position.X)
		end
	end)

	hitArea.InputChanged:Connect(function(inp)
		if inp == activeTouchId
		or (activeTouchId and inp.UserInputType == Enum.UserInputType.MouseMovement) then
			applyX(inp.Position.X)
		end
	end)

	-- Global move for touch (finger may leave the hit area while dragging)
	local _sliderMove = UIS.InputChanged:Connect(function(inp)
		if activeTouchId == nil then return end
		if inp.UserInputType == Enum.UserInputType.Touch
		or inp.UserInputType == Enum.UserInputType.MouseMovement then
			applyX(inp.Position.X)
		end
	end)
	table.insert(_G.V0idConnections, _sliderMove)

	local _sliderEnd = UIS.InputEnded:Connect(function(inp)
		if inp == activeTouchId
		or inp.UserInputType == Enum.UserInputType.MouseButton1
		or inp.UserInputType == Enum.UserInputType.Touch then
			activeTouchId = nil
		end
	end)
	table.insert(_G.V0idConnections, _sliderEnd)
end

