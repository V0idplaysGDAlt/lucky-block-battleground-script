do
	local p = tabPages["Kill"]

	-- ── Shared state ─────────────────────────────────
	local killEnabled  = false
	local killThread   = nil
	local crescEnabled = false
	local crescThread  = nil

	-- Spawn loop mirror state (controlled from here when we die)
	local spawnLoopRunning = false
	local spawnLoopThread  = nil

	-- ── Base detection ───────────────────────────────
	local spawnNames = {"Spawn1","Spawn2","Spawn3","Spawn4","Spawn5","Spawn6","Spawn7","Spawn8"}
	local spawnRegions = {}

	local function buildSpawnRegions()
		spawnRegions = {}
		for _, name in ipairs(spawnNames) do
			local sm = workspace:FindFirstChild(name)
			if not sm then continue end
			local anchor = sm:FindFirstChild("SpawnLocation") or sm:FindFirstChildWhichIsA("BasePart")
			if not anchor then
				for _, d in ipairs(sm:GetDescendants()) do
					if d:IsA("BasePart") then anchor = d; break end
				end
			end
			if anchor and anchor:IsA("BasePart") then
				table.insert(spawnRegions, {
					pos    = anchor.Position,
					radius = 60,
					yMin   = anchor.Position.Y - 20,
					yMax   = anchor.Position.Y + 40,
				})
			end
		end
	end
	buildSpawnRegions()

	local function isInBase(pos)
		if #spawnRegions == 0 then buildSpawnRegions() end
		for _, region in ipairs(spawnRegions) do
			local dx = pos.X - region.pos.X
			local dz = pos.Z - region.pos.Z
			if math.sqrt(dx*dx + dz*dz) <= region.radius
			and pos.Y >= region.yMin and pos.Y <= region.yMax then
				return true
			end
		end
		return false
	end

	-- ── Tool finders ─────────────────────────────────
	local function findTool(namePattern)
		local bp = player:FindFirstChild("Backpack")
		if bp then
			for _, t in ipairs(bp:GetChildren()) do
				if t:IsA("Tool") and t.Name:lower():find(namePattern) then return t end
			end
		end
		if character then
			for _, t in ipairs(character:GetChildren()) do
				if t:IsA("Tool") and t.Name:lower():find(namePattern) then return t end
			end
		end
		return nil
	end

	local function findPectrals()  return findTool("pectral") end
	local function findCrescendo() return findTool("crescendo") or findTool("cresc") end

	local function equipTool(tool)
		if not tool then return end
		if tool.Parent == character then return end
		pcall(function() tool.Parent = player.Backpack end)
		task.wait(0.05)
		pcall(function() humanoid:EquipTool(tool) end)
		task.wait(0.1)
	end

	-- ── Attack with Pectrals ─────────────────────────
	local function attackWithTool(tool)
		if tool.Parent ~= character then
			pcall(function() humanoid:EquipTool(tool) end)
			task.wait(0.05)
		end
		pcall(function()
			local handle = tool:FindFirstChild("Handle")
			if handle then
				local cd = handle:FindFirstChildOfClass("ClickDetector")
				if cd then pcall(function() fireClickDetector(cd) end) end
			end
			for _, v in ipairs(tool:GetDescendants()) do
				if v:IsA("RemoteEvent") then
					local n = v.Name:lower()
					if n:find("hit") or n:find("damage") or n:find("attack")
					or n:find("swing") or n:find("click") or n:find("activate") then
						pcall(function() v:FireServer() end)
					end
				end
			end
			local act = tool:FindFirstChild("Activate")
			if act and act:IsA("BindableEvent") then pcall(function() act:Fire() end) end
			pcall(function() tool:Activate() end)
		end)
	end

	-- ── Get valid targets (out of base, alive) ────────
	local function getTargets()
		local targets = {}
		for _, plr in ipairs(game.Players:GetPlayers()) do
			if plr == player then continue end
			local char2  = plr.Character
			local hum2   = char2 and char2:FindFirstChildOfClass("Humanoid")
			local root2  = char2 and char2:FindFirstChild("HumanoidRootPart")
			if not char2 or not hum2 or not root2 then continue end
			if hum2.Health <= 0 then continue end
			if isInBase(root2.Position) then continue end
			table.insert(targets, plr)
		end
		return targets
	end

	-- ── Spawn loop (fires all block remotes) ──────────
	local RS2 = game:GetService("ReplicatedStorage")
	local spawnRemotes = {"SpawnDiamondBlock","SpawnGalaxyBlock","SpawnLuckyBlock","SpawnRainbowBlock","SpawnSuperBlock"}

	local function startSpawnLoop()
		if spawnLoopRunning then return end
		spawnLoopRunning = true
		spawnLoopThread = task.spawn(function()
			while spawnLoopRunning do
				for _, rname in ipairs(spawnRemotes) do
					if not spawnLoopRunning then break end
					local rem = RS2:FindFirstChild(rname)
					if rem then pcall(function() rem:FireServer() end) end
				end
				task.wait(0.3)
			end
		end)
	end

	local function stopSpawnLoop()
		spawnLoopRunning = false
		spawnLoopThread  = nil
	end

	-- ── Pectrals kill loop ────────────────────────────
	local pectKillStatusLbl  -- forward ref, set in UI section

	-- ── Kill settings state ──────────────────────────
	local killMode      = "LoopTP"   -- "LoopTP" | "Remote"
	local killDirection = "Behind"   -- "Behind" | "Front" | "Left" | "Right"
	local killDistance  = 3.5        -- studs

	-- Compute offset vector in local space based on direction + distance
	local function getOffsetCF(root2)
		local vel = Vector3.zero
		pcall(function() vel = root2.AssemblyLinearVelocity end)
		local predictedPos = root2.Position + (vel * 0.1)
		local lookDir = vel.Magnitude > 2 and vel.Unit or root2.CFrame.LookVector
		local rightDir = root2.CFrame.RightVector

		local offset
		if killDirection == "Behind" then
			offset = lookDir * killDistance
		elseif killDirection == "Front" then
			offset = -lookDir * killDistance
		elseif killDirection == "Left" then
			offset = -rightDir * killDistance
		elseif killDirection == "Right" then
			offset = rightDir * killDistance
		else
			offset = lookDir * killDistance
		end

		local targetPos = predictedPos + offset
		return CFrame.new(targetPos, predictedPos)
	end

	local function runKillLoop()
		while killEnabled do
			-- Check if we are dead — wait for respawn
			if not character or not character:FindFirstChildOfClass("Humanoid")
			or character:FindFirstChildOfClass("Humanoid").Health <= 0 then
				task.wait(0.5)
				continue
			end

			local tool = findPectrals()
			if not tool then
				-- Start spawn loop so we keep getting swords while waiting
				startSpawnLoop()
				if pectKillStatusLbl then
					pectKillStatusLbl.Text = "⏳ Waiting for Pectrals..."
					pectKillStatusLbl.TextColor3 = Color3.fromRGB(255,200,80)
				end
				task.wait(0.5)
				continue
			end

			-- Have the tool — stop spawn loop, equip and go
			stopSpawnLoop()
			equipTool(tool)

			local targets = getTargets()
			if #targets == 0 then
				if pectKillStatusLbl then
					pectKillStatusLbl.Text = "⚠️ No targets outside base"
					pectKillStatusLbl.TextColor3 = Color3.fromRGB(255,200,80)
				end
				task.wait(0.5)
				continue
			end

			for _, plr in ipairs(targets) do
				if not killEnabled then break end

				-- Lock onto this target with a Heartbeat connection (same as crescendo)
				local pectTargetConn = nil
				local pectDone = false

				pectTargetConn = RunService.Heartbeat:Connect(function()
					if not killEnabled or pectDone then
						if pectTargetConn then pectTargetConn:Disconnect(); pectTargetConn = nil end
						return
					end

					local myHum = character and character:FindFirstChildOfClass("Humanoid")
					if not myHum or myHum.Health <= 0 then
						startSpawnLoop()
						pectDone = true
						if pectTargetConn then pectTargetConn:Disconnect(); pectTargetConn = nil end
						return
					end

					local char2  = plr.Character
					local hum2   = char2 and char2:FindFirstChildOfClass("Humanoid")
					local root2  = char2 and char2:FindFirstChild("HumanoidRootPart")
					if not char2 or not hum2 or not root2 or hum2.Health <= 0 then
						pectDone = true
						if pectTargetConn then pectTargetConn:Disconnect(); pectTargetConn = nil end
						return
					end
					if isInBase(root2.Position) then
						pectDone = true
						if pectTargetConn then pectTargetConn:Disconnect(); pectTargetConn = nil end
						return
					end

					local currentTool = findPectrals()
					if not currentTool then
						startSpawnLoop()
						pectDone = true
						if pectTargetConn then pectTargetConn:Disconnect(); pectTargetConn = nil end
						return
					end

					if pectKillStatusLbl then
						pectKillStatusLbl.Text = "⚔️ Targeting: " .. plr.Name
						pectKillStatusLbl.TextColor3 = Color3.fromRGB(255,80,80)
					end

					if killMode == "LoopTP" then
						-- Velocity-predicted continuous TP every Heartbeat frame
						pcall(function()
							local cf = getOffsetCF(root2)
							rootPart.CFrame = cf
							rootPart.AssemblyLinearVelocity  = Vector3.zero
							rootPart.AssemblyAngularVelocity = Vector3.zero
						end)
						attackWithTool(currentTool)
					end
					-- Remote mode is handled by its own task.spawn loop below,
					-- not inside this Heartbeat. Do nothing here for Remote.
				end)
				table.insert(_G.V0idConnections, pectTargetConn)

				-- Remote mode: blink to player → attack → blink back to base → repeat
				local remoteLoopThread = nil
				if killMode == "Remote" then
					remoteLoopThread = task.spawn(function()
						-- Find our base spawn location once
						local function getMyBase()
							for _, sName in ipairs({"Spawn1","Spawn2","Spawn3","Spawn4","Spawn5","Spawn6","Spawn7","Spawn8"}) do
								local sm = workspace:FindFirstChild(sName)
								if sm then
									local owner = sm:FindFirstChild("Owner")
									if owner and (owner.Value == player.Name or owner.Value == player) then
										local sl = sm:FindFirstChild("SpawnLocation")
										if sl then return sl.Position + Vector3.new(0, 5, 0) end
									end
								end
							end
							-- Fallback: remember where we started
							return rootPart and rootPart.Position or Vector3.new(0,0,0)
						end

						local basePos = getMyBase()

						while killEnabled and not pectDone do
							-- Re-check target still valid
							local char2b  = plr.Character
							local hum2b   = char2b and char2b:FindFirstChildOfClass("Humanoid")
							local root2b  = char2b and char2b:FindFirstChild("HumanoidRootPart")
							if not char2b or not hum2b or not root2b or hum2b.Health <= 0 then break end
							if isInBase(root2b.Position) then break end

							local tool2 = findPectrals()
							if not tool2 then break end

							if pectKillStatusLbl then
								pectKillStatusLbl.Text = "💨 Blinking to: " .. plr.Name
								pectKillStatusLbl.TextColor3 = Color3.fromRGB(255,80,80)
							end

							-- Blink TO player
							pcall(function()
								local cf = getOffsetCF(root2b)
								rootPart.CFrame = cf
								rootPart.AssemblyLinearVelocity  = Vector3.zero
								rootPart.AssemblyAngularVelocity = Vector3.zero
							end)

							-- Stay and attack for 0.5 seconds
							local attackEnd = tick() + 0.5
							while tick() < attackEnd and killEnabled and not pectDone do
								local tool3 = findPectrals()
								if not tool3 then break end
								attackWithTool(tool3)
								task.wait(0.08)
							end

							if not killEnabled or pectDone then break end

							if pectKillStatusLbl then
								pectKillStatusLbl.Text = "🏠 Returning to base..."
								pectKillStatusLbl.TextColor3 = Color3.fromRGB(180,180,100)
							end

							-- Blink BACK to base
							pcall(function()
								rootPart.CFrame = CFrame.new(basePos)
								rootPart.AssemblyLinearVelocity  = Vector3.zero
								rootPart.AssemblyAngularVelocity = Vector3.zero
							end)

							-- Brief pause at base before next blink
							task.wait(0.3)
						end
					end)
				end

				-- Wait until this target is dead/escaped before moving to next
				repeat task.wait(0.05) until pectDone or not killEnabled
				if pectTargetConn then pectTargetConn:Disconnect(); pectTargetConn = nil end
				if remoteLoopThread then
					pcall(function() task.cancel(remoteLoopThread) end)
					remoteLoopThread = nil
				end
			end

			task.wait(0.1)
		end
		stopSpawnLoop()
	end

	local function stopKill()
		killEnabled = false
		killThread  = nil
		stopSpawnLoop()
	end

	local function startKill()
		killEnabled = true
		killThread  = task.spawn(runKillLoop)
	end

	-- Hook CharacterAdded so when we respawn, kill loop re-evaluates naturally
	player.CharacterAdded:Connect(function(newChar)
		character = newChar
		humanoid  = newChar:WaitForChild("Humanoid")
		rootPart  = newChar:WaitForChild("HumanoidRootPart")
