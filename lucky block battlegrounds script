-- Auto-delete walls, forcefield checks and scripts from all spawns on load
do
	local spawnCleanNames = {"Spawn1","Spawn2","Spawn3","Spawn4","Spawn5","Spawn6","Spawn7","Spawn8"}
	for _, sName in ipairs(spawnCleanNames) do
		local sm = workspace:FindFirstChild(sName)
		if not sm then continue end

		-- Delete ForceFieldCheck
		local ffc = sm:FindFirstChild("ForceFieldCheck")
		if ffc then pcall(function() ffc:Destroy() end) end

		-- Delete Walls and everything inside
		local walls = sm:FindFirstChild("Walls")
		if walls then
			-- Kill the Script inside Walls first
			local ws = walls:FindFirstChild("Script")
			if ws then pcall(function() ws:Destroy() end) end

			-- Kill the Model and all its children
			local wm = walls:FindFirstChild("Model")
			if wm then
				for _, child in ipairs(wm:GetChildren()) do
					pcall(function() child:Destroy() end)
				end
				pcall(function() wm:Destroy() end)
			end

			-- Kill any remaining BaseParts directly in Walls (e.g. "Part")
			for _, child in ipairs(walls:GetChildren()) do
				pcall(function() child:Destroy() end)
			end

			pcall(function() walls:Destroy() end)
		end
	end
end

