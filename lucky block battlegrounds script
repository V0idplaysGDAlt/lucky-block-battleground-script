	local function makeKillOptionRow(yOff, label, options, default, onPick)
		local hdr = Instance.new("TextLabel"); hdr.Parent = p
		hdr.Size = UDim2.new(1,-20,0,16); hdr.Position = UDim2.new(0,10,0,yOff)
		hdr.BackgroundTransparency = 1; hdr.Text = label
		hdr.Font = Enum.Font.GothamBold; hdr.TextSize = 11
		hdr.TextColor3 = Color3.fromRGB(170,0,255); hdr.TextXAlignment = Enum.TextXAlignment.Left

		-- Use scale-based width so buttons always share the row evenly
		local gap   = 4
		local total = #options
		local btns  = {}

		for i, opt in ipairs(options) do
			local b = Instance.new("TextButton"); b.Parent = p
			-- Each button takes an equal share of (1 - left/right padding)
			local scaleW = (1 - 0.05) / total
			local offX   = 10 + (i-1) * (scaleW * 560 + gap)  -- 560 = approx page width
			-- Use UDim2 scale width so it adapts to actual page width
			b.Size = UDim2.new((1 / total) - 0.01, -gap, 0, 30)
			b.Position = UDim2.new((i-1) / total + 0.005, gap/2, 0, yOff + 18)
			b.Text = opt; b.Font = Enum.Font.GothamBold; b.TextSize = 11
			b.BorderSizePixel = 0; b.TextColor3 = Color3.new(1,1,1)
			b.BackgroundColor3 = (opt == default) and Color3.fromRGB(100,0,180) or Color3.fromRGB(20,0,40)
			local bc = Instance.new("UICorner"); bc.CornerRadius = UDim.new(0,5); bc.Parent = b
			table.insert(btns, {btn=b, opt=opt})
		end

		-- Wire clicks after all buttons exist so the closure captures the full btns table
		for _, entry in ipairs(btns) do
			local clickedOpt = entry.opt
			local clickedBtn = entry.btn
			clickedBtn.MouseButton1Click:Connect(function()
				-- Update all highlights
				for _, x in ipairs(btns) do
					x.btn.BackgroundColor3 = (x.opt == clickedOpt)
						and Color3.fromRGB(100,0,180)
						or  Color3.fromRGB(20,0,40)
				end
				onPick(clickedOpt)
			end)
		end

		return 18 + 34  -- total height used
	end

