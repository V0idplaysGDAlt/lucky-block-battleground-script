--------------------------------------------------
-- TOGGLE GUI (touch + click)
--------------------------------------------------

toggleButton.MouseButton1Click:Connect(function()
	frame.Visible = not frame.Visible
end)
toggleButton.TouchTap:Connect(function()
	frame.Visible = not frame.Visible
end)

--------------------------------------------------
-- DRAG MAIN FRAME — uses raw touch delta, no tween
-- On mobile the frame is scale-based so dragging
-- is disabled (it takes up most of screen anyway)
--------------------------------------------------

if not isMobile then
	local dragging, dragStart, startPos

	titleBar.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1
		or input.UserInputType == Enum.UserInputType.Touch then
			dragging = true; dragStart = input.Position; startPos = frame.Position
		end
	end)

	local _dfm = UIS.InputChanged:Connect(function(input)
		if not dragging then return end
		if input.UserInputType ~= Enum.UserInputType.MouseMovement
		and input.UserInputType ~= Enum.UserInputType.Touch then return end
		local delta = input.Position - dragStart
		local vp = getVP()
		local fw = frame.AbsoluteSize.X
		local fh = frame.AbsoluteSize.Y
		local newX = math.clamp(startPos.X.Offset + delta.X, 0, vp.X - fw)
		local newY = math.clamp(startPos.Y.Offset + delta.Y, 0, vp.Y - fh)
		frame.Position = UDim2.new(0, newX, 0, newY)
	end)
	table.insert(_G.V0idConnections, _dfm)

	local _dfe = UIS.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1
		or input.UserInputType == Enum.UserInputType.Touch then
			dragging = false
		end
	end)
	table.insert(_G.V0idConnections, _dfe)
end

--------------------------------------------------
-- DRAG TOGGLE BUTTON — clamped to screen
--------------------------------------------------

do
	local btnDragging, btnStart, btnStartPos
	local TAP_THRESHOLD = 8  -- pixels — less than this = tap not drag

	toggleButton.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1
		or input.UserInputType == Enum.UserInputType.Touch then
			btnDragging = true
			btnStart = input.Position
			btnStartPos = toggleButton.Position
		end
	end)

	local _tbm = UIS.InputChanged:Connect(function(input)
		if not btnDragging then return end
		if input.UserInputType ~= Enum.UserInputType.MouseMovement
		and input.UserInputType ~= Enum.UserInputType.Touch then return end
		local delta = input.Position - btnStart
		if delta.Magnitude < TAP_THRESHOLD then return end  -- don't drag on tap
		local vp = getVP()
		local sz = M.toggleSz
		local newX = math.clamp(btnStartPos.X.Offset + delta.X, 0, vp.X - sz)
		local newY = math.clamp(btnStartPos.Y.Offset + delta.Y, 0, vp.Y - sz)
		toggleButton.Position = UDim2.new(0, newX, 0, newY)
	end)
	table.insert(_G.V0idConnections, _tbm)

	local _tbe = UIS.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1
		or input.UserInputType == Enum.UserInputType.Touch then
			btnDragging = false
		end
	end)
	table.insert(_G.V0idConnections, _tbe)
end

