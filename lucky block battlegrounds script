				info.lbl.Text = "out of base"; info.lbl.TextColor3 = Color3.fromRGB(255,100,100)
			end
		end

		listScroll.CanvasSize = UDim2.new(0,0,0, listLayout.AbsoluteContentSize.Y + 4)
	end

