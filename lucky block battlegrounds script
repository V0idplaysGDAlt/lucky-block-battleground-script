local espBoxEnabled      = false
local espTracerEnabled   = false
local espNameEnabled     = false
local espHealthEnabled   = false
local espDistEnabled     = false
local espHeadDotEnabled  = false
local espSkeletonEnabled = false
local espChamsEnabled    = false
local espOutlineEnabled  = false
local espRainbow         = false
local espColor           = Color3.fromRGB(255, 60, 60)
local espBoxType         = "Normal"
local espTracerOrigin    = "Bottom"
local espConnection      = nil

local _rainbowHue = 0
local function ensureRainbow()
	if _G.V0idRainbowConn then return end
	_G.V0idRainbowConn = RunService.Heartbeat:Connect(function()
		_rainbowHue = (_rainbowHue + 0.0015) % 1
	end)
	table.insert(_G.V0idConnections, _G.V0idRainbowConn)
end
ensureRainbow()
local function getRainbow() return Color3.fromHSV(_rainbowHue, 1, 1) end

local SKELETON_PAIRS = {
	{"Head","UpperTorso"},{"Head","Torso"},
	{"UpperTorso","LowerTorso"},{"LowerTorso","Torso"},
	{"Torso","Left Arm"},{"Torso","Right Arm"},
	{"UpperTorso","LeftUpperArm"},{"UpperTorso","RightUpperArm"},
	{"LeftUpperArm","LeftLowerArm"},{"RightUpperArm","RightLowerArm"},
	{"LeftLowerArm","LeftHand"},{"RightLowerArm","RightHand"},
	{"Torso","Left Leg"},{"Torso","Right Leg"},
	{"LowerTorso","LeftUpperLeg"},{"LowerTorso","RightUpperLeg"},
	{"LeftUpperLeg","LeftLowerLeg"},{"RightUpperLeg","RightLowerLeg"},
	{"LeftLowerLeg","LeftFoot"},{"RightLowerLeg","RightFoot"},
}

local function newDrawing(kind, props)
	local d = Drawing.new(kind)
	for k,v in pairs(props) do d[k]=v end
	return d
end

local function getPool(uid)
	if not _G.V0idEspPool[uid] then
		_G.V0idEspPool[uid] = {
			boxOutline    = newDrawing("Square",{Visible=false,Filled=false,Thickness=3,  Color=Color3.new(0,0,0)}),
			box           = newDrawing("Square",{Visible=false,Filled=false,Thickness=1.5}),
			boxFill       = newDrawing("Square",{Visible=false,Filled=true, Transparency=0.5}),
			corners       = {},
			tracerOutline = newDrawing("Line",{Visible=false,Thickness=3,Color=Color3.new(0,0,0)}),
			tracer        = newDrawing("Line",{Visible=false,Thickness=1}),
			name          = newDrawing("Text",{Visible=false,Size=13,Outline=true,Center=true}),
			hpBg          = newDrawing("Square",{Visible=false,Filled=true,Color=Color3.fromRGB(30,30,30)}),
			hpFill        = newDrawing("Square",{Visible=false,Filled=true}),
			dist          = newDrawing("Text",{Visible=false,Size=11,Outline=true,Center=true,Color=Color3.fromRGB(200,200,200)}),
			headDotOutline= newDrawing("Circle",{Visible=false,Filled=true,Radius=6,Color=Color3.new(0,0,0)}),
			headDot       = newDrawing("Circle",{Visible=false,Filled=true,Radius=4}),
			bones         = {},
		}
		for _=1,8  do table.insert(_G.V0idEspPool[uid].corners, newDrawing("Line",{Visible=false,Thickness=2})) end
		for _=1,#SKELETON_PAIRS do table.insert(_G.V0idEspPool[uid].bones, newDrawing("Line",{Visible=false,Thickness=1})) end
	end
	return _G.V0idEspPool[uid]
end

local function hidePool(pool)
	pool.box.Visible=false; pool.boxOutline.Visible=false; pool.boxFill.Visible=false
	pool.tracer.Visible=false; pool.tracerOutline.Visible=false
	pool.name.Visible=false; pool.hpBg.Visible=false; pool.hpFill.Visible=false
	pool.dist.Visible=false; pool.headDot.Visible=false; pool.headDotOutline.Visible=false
	for _,c in ipairs(pool.corners) do c.Visible=false end
	for _,b in ipairs(pool.bones)   do b.Visible=false end
end

local function destroyAllPools()
	for uid, pool in pairs(_G.V0idEspPool) do
		for _, key in ipairs({"box","boxOutline","boxFill","tracer","tracerOutline","name","hpBg","hpFill","dist","headDot","headDotOutline"}) do
			pcall(function() pool[key]:Remove() end)
		end
		for _,c in ipairs(pool.corners) do pcall(function() c:Remove() end) end
		for _,b in ipairs(pool.bones)   do pcall(function() b:Remove() end) end
		_G.V0idEspPool[uid] = nil
	end
end

local function destroyAllChams()
	for uid, h in pairs(_G.V0idChams) do
		pcall(function() h:Destroy() end)
	end
	_G.V0idChams = {}
end

local function stopEsp()
	if espConnection then espConnection:Disconnect(); espConnection = nil end
	destroyAllPools(); destroyAllChams()
end

local function anyEspActive()
	return espBoxEnabled or espTracerEnabled or espNameEnabled
		or espHealthEnabled or espDistEnabled or espHeadDotEnabled
		or espSkeletonEnabled or espChamsEnabled
end

local function startEsp()
	if espConnection then espConnection:Disconnect(); espConnection = nil end
	local _frame = 0
	espConnection = RunService.Heartbeat:Connect(function()
		_frame += 1
		if _frame % 2 ~= 0 then return end
		local camera = workspace.CurrentCamera
		if not camera then return end
		local vp = camera.ViewportSize
		local active = {}
		local col = espRainbow and getRainbow() or espColor

		for _, plr in ipairs(game.Players:GetPlayers()) do
			if plr == player then continue end
			local char2 = plr.Character
			if not char2 then continue end
			local root2 = char2:FindFirstChild("HumanoidRootPart")
			local hum2  = char2:FindFirstChildOfClass("Humanoid")
			local head2 = char2:FindFirstChild("Head")
			if not root2 or not hum2 or not head2 then continue end
			if hum2.Health <= 0 then continue end

			local uid = plr.UserId
			active[uid] = true
			local pool = getPool(uid)

			local sp,  onScreen = camera:WorldToViewportPoint(root2.Position)
			local hsp, _        = camera:WorldToViewportPoint(head2.Position + Vector3.new(0,0.7,0))
			local fsp, _        = camera:WorldToViewportPoint(root2.Position - Vector3.new(0,3,0))
			local height = math.abs(hsp.Y - fsp.Y)
			local width  = height * 0.55
			local bx0    = sp.X - width/2
			local by0    = hsp.Y
			local dist   = math.floor((rootPart.Position - root2.Position).Magnitude)

			pool.box.Visible=false; pool.boxOutline.Visible=false; pool.boxFill.Visible=false
			for _,c in ipairs(pool.corners) do c.Visible=false end
			if espBoxEnabled and onScreen then
				if espBoxType == "Normal" then
					if espOutlineEnabled then
						pool.boxOutline.Size=Vector2.new(width+3,height+3); pool.boxOutline.Position=Vector2.new(bx0-1.5,by0-1.5); pool.boxOutline.Visible=true
					end
					pool.box.Size=Vector2.new(width,height); pool.box.Position=Vector2.new(bx0,by0); pool.box.Color=col; pool.box.Visible=true
				elseif espBoxType == "Filled" then
					if espOutlineEnabled then
						pool.boxOutline.Size=Vector2.new(width+3,height+3); pool.boxOutline.Position=Vector2.new(bx0-1.5,by0-1.5); pool.boxOutline.Visible=true
					end
					pool.boxFill.Size=Vector2.new(width,height); pool.boxFill.Position=Vector2.new(bx0,by0); pool.boxFill.Color=col; pool.boxFill.Visible=true
					pool.box.Size=Vector2.new(width,height); pool.box.Position=Vector2.new(bx0,by0); pool.box.Color=col; pool.box.Visible=true
				elseif espBoxType == "Corner" then
					local cLen=width*0.28
					local cd={
						{Vector2.new(bx0,by0),              {Vector2.new(cLen,0),  Vector2.new(0,cLen)}},
						{Vector2.new(bx0+width,by0),        {Vector2.new(-cLen,0), Vector2.new(0,cLen)}},
						{Vector2.new(bx0,by0+height),       {Vector2.new(cLen,0),  Vector2.new(0,-cLen)}},
						{Vector2.new(bx0+width,by0+height), {Vector2.new(-cLen,0), Vector2.new(0,-cLen)}},
					}
					local ci=1
					for _,corn in ipairs(cd) do
						for _,dir in ipairs(corn[2]) do
							local ln=pool.corners[ci]
							if ln then ln.From=corn[1]; ln.To=corn[1]+dir; ln.Color=col; ln.Visible=true end
							ci+=1
						end
					end
				end
			end

			pool.tracer.Visible=false; pool.tracerOutline.Visible=false
			if espTracerEnabled and onScreen then
				local fromY=vp.Y
				if espTracerOrigin=="Center" then fromY=vp.Y/2 elseif espTracerOrigin=="Top" then fromY=0 end
				local tFrom=Vector2.new(vp.X/2,fromY); local tTo=Vector2.new(sp.X,fsp.Y)
				if espOutlineEnabled then
					pool.tracerOutline.From=tFrom; pool.tracerOutline.To=tTo; pool.tracerOutline.Visible=true
				end
				pool.tracer.From=tFrom; pool.tracer.To=tTo; pool.tracer.Color=col; pool.tracer.Visible=true
			end

			pool.name.Visible=false
			if espNameEnabled and onScreen then
				pool.name.Text=plr.Name; pool.name.Color=col
				pool.name.Position=Vector2.new(sp.X,hsp.Y-17); pool.name.Visible=true
			end

			pool.hpBg.Visible=false; pool.hpFill.Visible=false
			if espHealthEnabled and onScreen then
				local hpR=math.clamp(hum2.Health/hum2.MaxHealth,0,1)
				local barH=height*hpR; local barX=bx0-7
				pool.hpBg.Size=Vector2.new(4,height); pool.hpBg.Position=Vector2.new(barX,by0); pool.hpBg.Visible=true
				pool.hpFill.Size=Vector2.new(4,barH); pool.hpFill.Position=Vector2.new(barX,by0+(height-barH))
				pool.hpFill.Color=Color3.fromRGB(math.floor(255*(1-hpR)),math.floor(255*hpR),0); pool.hpFill.Visible=true
			end

			pool.dist.Visible=false
			if espDistEnabled and onScreen then
				pool.dist.Text=dist.."m"; pool.dist.Position=Vector2.new(sp.X,fsp.Y+3); pool.dist.Visible=true
			end

			pool.headDot.Visible=false; pool.headDotOutline.Visible=false
			if espHeadDotEnabled and onScreen then
				if espOutlineEnabled then
					pool.headDotOutline.Position=Vector2.new(hsp.X,hsp.Y); pool.headDotOutline.Visible=true
				end
				pool.headDot.Position=Vector2.new(hsp.X,hsp.Y); pool.headDot.Color=col; pool.headDot.Visible=true
			end

			for _,b in ipairs(pool.bones) do b.Visible=false end
			if espSkeletonEnabled then
				for i,pair in ipairs(SKELETON_PAIRS) do
					local pA=char2:FindFirstChild(pair[1]); local pB=char2:FindFirstChild(pair[2])
					if pA and pB then
						local sA,okA=camera:WorldToViewportPoint(pA.Position)
						local sB,okB=camera:WorldToViewportPoint(pB.Position)
						if okA and okB and pool.bones[i] then
							pool.bones[i].From=Vector2.new(sA.X,sA.Y); pool.bones[i].To=Vector2.new(sB.X,sB.Y)
							pool.bones[i].Color=col; pool.bones[i].Visible=true
						end
					end
				end
			end

			if espChamsEnabled then
				if not _G.V0idChams[uid] or not _G.V0idChams[uid].Parent then
					local h=Instance.new("Highlight")
					h.Adornee=char2; h.FillColor=col; h.OutlineColor=col
					h.FillTransparency=0.4; h.OutlineTransparency=0
					h.DepthMode=Enum.HighlightDepthMode.AlwaysOnTop; h.Parent=char2
					_G.V0idChams[uid]=h
				else
					_G.V0idChams[uid].FillColor=col; _G.V0idChams[uid].OutlineColor=col
				end
			else
				if _G.V0idChams[uid] then pcall(function() _G.V0idChams[uid]:Destroy() end); _G.V0idChams[uid]=nil end
			end
		end

		for uid, pool in pairs(_G.V0idEspPool) do
			if not active[uid] then
				hidePool(pool)
				if _G.V0idChams[uid] then pcall(function() _G.V0idChams[uid]:Destroy() end); _G.V0idChams[uid]=nil end
			end
		end
	end)
	table.insert(_G.V0idConnections, espConnection)
end

local function refreshEsp()
	if anyEspActive() then
		if not espConnection then startEsp() end
	else
		stopEsp()
	end
end

