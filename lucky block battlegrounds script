local aimbotEnabled    = false
local aimbotFOV        = 120
local aimbotSmoothing  = 10
local aimbotTeamCheck  = false
local aimbotVisCheck   = false
local aimbotKey        = Enum.KeyCode.Q
local aimbotToggleMode = false
local aimbotToggleState = false
local aimbotMouseBtn   = nil

local function getAimbotTarget()
	local camera = workspace.CurrentCamera
	local screenCenter = Vector2.new(camera.ViewportSize.X / 2, camera.ViewportSize.Y / 2)
	local closest = nil
	local closestDist = math.huge
	for _, plr in ipairs(game.Players:GetPlayers()) do
		if plr == player then continue end
		if aimbotTeamCheck and plr.Team == player.Team then continue end
		local char2 = plr.Character
		if not char2 then continue end
		local hum2    = char2:FindFirstChildOfClass("Humanoid")
		local aimPart = char2:FindFirstChild(_G.V0idAimBone or "Head") or char2:FindFirstChild("Head")
		if not aimPart or not hum2 or hum2.Health <= 0 then continue end
		local screenPos, onScreen = camera:WorldToViewportPoint(aimPart.Position)
		if not onScreen then continue end
		if aimbotVisCheck then
			local ray = workspace:Raycast(camera.CFrame.Position, aimPart.Position - camera.CFrame.Position, RaycastParams.new())
			if ray and ray.Instance and not ray.Instance:IsDescendantOf(char2) then continue end
		end
		local dist2D = (Vector2.new(screenPos.X, screenPos.Y) - screenCenter).Magnitude
		if dist2D < closestDist then
			closestDist = dist2D
			closest = aimPart
		end
	end
	return closest
end

local aimbotConnection = nil
local function startAimbot()
	if aimbotConnection then aimbotConnection:Disconnect(); aimbotConnection = nil end
	local lockedTarget = nil
	aimbotConnection = RunService.RenderStepped:Connect(function()
		if not aimbotEnabled then lockedTarget = nil; return end
		local camera = workspace.CurrentCamera
		local keyActive = false
		if aimbotMouseBtn ~= nil then
			keyActive = UIS:IsMouseButtonPressed(aimbotMouseBtn)
		else
			pcall(function() keyActive = UIS:IsKeyDown(aimbotKey) end)
		end
		local shouldAim = aimbotToggleMode and aimbotToggleState or (not aimbotToggleMode and keyActive)
		if shouldAim then
			local t = getAimbotTarget()
			if t and t.Parent then lockedTarget = t end
			if lockedTarget and lockedTarget.Parent then
				local alpha = math.clamp(1 / math.max(aimbotSmoothing, 1), 0.02, 1)
				local from = camera.CFrame
				local to = CFrame.new(from.Position, lockedTarget.Position)
				pcall(function() workspace.CurrentCamera.CFrame = from:Lerp(to, alpha) end)
			end
		else
			lockedTarget = nil
		end
	end)
	table.insert(_G.V0idConnections, aimbotConnection)
end
startAimbot()

